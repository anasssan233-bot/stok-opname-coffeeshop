# Salin file ini menjadi ".env" lalu isi dengan connection string database Postgres kamu.
# Dapatkan gratis di https://neon.tech (klik "Create a project", lalu copy "Connection string").

DATABASE_URL=postgresql://user:password@ep-xxxx.aws.neon.tech/dbname?sslmode=require

# Ganti dengan string acak sendiri sebelum dipakai secara nyata / online.
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

# Biarkan kosong / hapus baris ini kalau connect ke Neon (butuh SSL).
# Isi "false" hanya kalau menjalankan Postgres lokal di komputer sendiri tanpa SSL.
# PGSSL=false
